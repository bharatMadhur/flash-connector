APP_NAME=flash-connector
ENVIRONMENT=development
RUNTIME_MODE=sandbox
DEBUG=false

POSTGRES_USER=flash
POSTGRES_PASSWORD=flash
POSTGRES_DB=flash_connector

DATABASE_URL=postgresql+psycopg2://flash:flash@postgres:5432/flash_connector
REDIS_URL=redis://redis:6379/0

SESSION_SECRET=change-me-session-secret
SESSION_COOKIE_NAME=flash_connector_session
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAMESITE=lax
SESSION_COOKIE_MAX_AGE=1209600

API_KEY_HMAC_SECRET=change-me-api-key-secret

OIDC_ISSUER_URL=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URI=http://localhost:8000/auth/callback
OIDC_POST_LOGOUT_REDIRECT_URI=http://localhost:8000/login
OIDC_SCOPES=openid profile email
OIDC_ROLE_CLAIM=realm_access.roles
OIDC_EMAIL_CLAIM=email
OIDC_NAME_CLAIM=name
OIDC_TENANT_CLAIM=flash_tenant
OIDC_ROLE_MAPPING_JSON={"owner":"owner","admin":"admin","dev":"dev","viewer":"viewer"}
OIDC_DEFAULT_ROLE=viewer
OIDC_AUTO_CREATE_TENANT=false
OIDC_METADATA_CACHE_SECONDS=300
LOCAL_AUTH_ENABLED=false
LOCAL_AUTH_USERNAME=
LOCAL_AUTH_PASSWORD=
LOCAL_AUTH_EMAIL=
LOCAL_AUTH_ROLE=owner
LOCAL_BOOTSTRAP_API_KEY=
LOCAL_BOOTSTRAP_API_KEY_NAME=local-bootstrap
LOCAL_BOOTSTRAP_API_KEY_RATE_LIMIT_PER_MIN=600
LOCAL_BOOTSTRAP_API_KEY_MONTHLY_QUOTA=1000000

OPENAI_API_KEY=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_BASE_URL=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_VERSION=
AZURE_AI_FOUNDRY_API_KEY=
AZURE_AI_FOUNDRY_BASE_URL=
AZURE_AI_FOUNDRY_ENDPOINT=
AZURE_AI_FOUNDRY_API_VERSION=
PLATFORM_PROVIDER_KEYS_JSON={}
TENANT_SECRET_STORAGE_DIR=/tmp/flash_connector_secrets
TENANT_SECRET_ENCRYPTION_KEY=
TENANT_SECRET_ENCRYPTION_KEYS_JSON={}
TENANT_SECRET_ACTIVE_KEY_ID=

CORS_ORIGINS=http://localhost:8000

SINGLE_TENANT_MODE=false
DEFAULT_TENANT_NAME=Default Tenant

QUEUE_NAME=jobs
JOB_TIMEOUT_SECONDS=180
MAX_CONCURRENCY=1
PROVIDER_BATCH_POLL_INTERVAL_SECONDS=20
PROVIDER_BATCH_MAX_POLL_ATTEMPTS=720
RATE_LIMIT_ALLOW_IN_MEMORY_FALLBACK_NONPROD=true
API_KEY_LAST_USED_UPDATE_INTERVAL_SECONDS=300
TENANT_HIERARCHY_MAX_DEPTH=8
